# Maintainer: Fahry <fahry@example.com>

pkgname=airi-bin
_pkgname=AIRI
pkgver=0.9.0_alpha.1
_tag_ver=$(echo "${pkgver}" | tr '_' '-')
_electronversion=40
pkgrel=1
pkgdesc="Self-hosted AI companion application (Prebuilt version, uses system-wide electron)"
arch=('aarch64' 'x86_64')
url="https://airi.moeru.ai/docs/"
_ghurl="https://github.com/moeru-ai/airi"
license=('MIT')
conflicts=("${pkgname%-bin}")
provides=("${pkgname%-bin}=${pkgver}")
depends=(
  "electron${_electronversion}"
  'xsel'
)
options=(
  '!emptydirs'
  '!strip'
)
source=(
  "LICENSE-${pkgver}::https://raw.githubusercontent.com/moeru-ai/airi/v${_tag_ver}/LICENSE"
  "${pkgname%-bin}.sh"
)
source_aarch64=("${pkgname%-bin}-${pkgver}-aarch64.rpm::${_ghurl}/releases/download/v${_tag_ver}/${_pkgname}-${_tag_ver}-linux-aarch64.rpm")
source_x86_64=("${pkgname%-bin}-${pkgver}-x86_64.rpm::${_ghurl}/releases/download/v${_tag_ver}/${_pkgname}-${_tag_ver}-linux-x86_64.rpm")
sha256sums=('f334260edf0508041280b534ca9d0abd5a02a9626c1d2e20a556ac4eb72b07f9'
            '59bcccb0397373ba69c2fdf28aee8b244e4601248cff391a79a4b18feab7bc18')
sha256sums_aarch64=('eaa6015a68d140ee9301277417632f4b0d7928019a924f603dc0709a6c7a82b9')
sha256sums_x86_64=('0b8a51fe086cd31d7a847ee490e13fcdf5db3e952ea2e9186e2b975c2c761949')

_get_electron_version() {
  local _elec_ver="$(strings "${srcdir}/opt/${_pkgname}/${pkgname%-bin}" | grep '^Chrome/[0-9.]* Electron/[0-9]' | cut -d'/' -f3 | cut -d'.' -f1)"
  echo -e "Detected bundled Electron version: \033[1;31m${_elec_ver}\033[0m"
  echo -e "Using system Electron version: \033[1;32m${_electronversion}\033[0m"
}

prepare() {
  # Substitute placeholders in launcher script
  sed -i -e "
    s/@electronversion@/${_electronversion}/g
    s/@appname@/${pkgname%-bin}/g
    s/@runname@/app.asar/g
    s/@cfgdirname@/ai.moeru.${pkgname%-bin}/g
    s/@options@/env ELECTRON_OZONE_PLATFORM_HINT=auto/g
  " "${srcdir}/${pkgname%-bin}.sh"

  # Display Electron version info
  _get_electron_version

  # Fix desktop file paths
  sed -i "s/\/opt\/${_pkgname}\///g" "${srcdir}/usr/share/applications/${pkgname%-bin}.desktop"

  # Link xsel for clipboard support
  ln -sf "/usr/bin/xsel" "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked/node_modules/clipboardy/fallbacks/linux/xsel"

  # Remove unnecessary platform-specific files
  rm -rf \
    "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked/node_modules/electron-click-drag-plugin/build/Release/"{darwin-*,win32-*} \
    "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked/node_modules/onnxruntime-node/bin/napi-v3/"{darwin,win32}

  # Remove opposite architecture files
  case "${CARCH}" in
    aarch64)
      rm -rf "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked/node_modules/onnxruntime-node/bin/napi-v3/linux/x64"
      ;;
    x86_64)
      rm -rf "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked/node_modules/onnxruntime-node/bin/napi-v3/linux/arm64"
      ;;
  esac
}

package() {
  # Install launcher script
  install -Dm755 "${srcdir}/${pkgname%-bin}.sh" "${pkgdir}/usr/bin/${pkgname%-bin}"

  # Install application files
  install -Dm644 "${srcdir}/opt/${_pkgname}/resources/app.asar" -t "${pkgdir}/usr/lib/${pkgname%-bin}"
  cp -Pr --no-preserve=ownership "${srcdir}/opt/${_pkgname}/resources/app.asar.unpacked" "${pkgdir}/usr/lib/${pkgname%-bin}"

  # Install icons
  local _icon_sizes=(16x16 32x32 48x48 64x64 128x128 256x256)
  for _icons in "${_icon_sizes[@]}"; do
    install -Dm644 "${srcdir}/usr/share/icons/hicolor/${_icons}/apps/${pkgname%-bin}.png" \
      -t "${pkgdir}/usr/share/icons/hicolor/${_icons}/apps"
  done

  # Install desktop entry
  install -Dm644 "${srcdir}/usr/share/applications/${pkgname%-bin}.desktop" -t "${pkgdir}/usr/share/applications"

  # Install license
  install -Dm644 "${srcdir}/LICENSE-${pkgver}" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
